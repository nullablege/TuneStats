@model ErrorViewModel
@{
    Layout = null;
    ViewData["Title"] = "Hata";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TuneStats - Hata</title>
    <link rel="stylesheet" href="~/style.css" asp-append-version="true">
</head>
<body>
    <main class="content" style="min-height:100dvh;display:grid;place-items:center;">
        <section class="chart-card" style="max-width:520px;width:100%;">
            <div class="chart-header">
                <h1 class="chart-title">Beklenmeyen bir hata oluştu</h1>
            </div>
            <p class="item-meta" style="margin-bottom:20px;">İşlem tamamlanamadı. Ana ekrana dönüp tekrar deneyebilirsiniz.</p>
            @if (Model.ShowRequestId)
            {
                <p class="item-meta">İstek kodu: <code>@Model.RequestId</code></p>
            }
            <a class="pagination-btn active" asp-controller="Home" asp-action="Index">Dashboard'a dön</a>
        </section>
    </main>
</body>
</html>
